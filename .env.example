# Required: Groq API key for LLM calls in main.jac
# Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: use pre-built synthetic data instead of calling the LLM
# Set to "true" to skip LLM calls (good for demos/testing)
USE_SYNTH=false

# Optional: custom path to synthetic data directory (default: data/raw/synthetic_visualization_sinks)
# SYNTH_DIR=data/raw/synthetic_visualization_sinks

# Optional: custom log file path for the ACP agent
# AGENT_LOG_PATH=logs/agent.log

# Optional: enable verbose transport debugging
# DEBUG_TRANSPORT=false
